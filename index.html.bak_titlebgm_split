                    if (!inv.type.isBoss && !inv.type.verticalMove && !inv.type.randomMove && !inv.type.circleMove && !inv.type.canHide) { if (inv.x + inv.width > 390 || inv.x < 10) edge = true; }
                });
                if (edge) { this.invaderDirection *= -1; this.invaders.forEach(inv => { if(!inv.type.isBoss && !inv.type.verticalMove && !inv.type.randomMove && !inv.type.circleMove && !inv.type.canHide && inv.y < 400) inv.y += 15; }); }
                if (Math.random() < (stageCfg.isMidBoss ? 0.02 : 0.005) && this.invaders.length > 0) {
                    const s = this.invaders[Math.floor(Math.random() * this.invaders.length)]; if(s.isVisible) {
                        const cfg = s.type; let vx = 0, vy = (Number.isFinite(stageCfg.enemyBulletVy) ? stageCfg.enemyBulletVy : 3);
                        if(s.typeName === 'tengu' || s.type.isBoss) { 
                            const dx = (this.player.x + this.player.width/2) - (s.x + s.width/2);
                            const dy = (this.player.y + this.player.height/2) - (s.y + s.height);
