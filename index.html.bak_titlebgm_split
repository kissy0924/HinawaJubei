                const tl = (id, key) => { const b = document.getElementById(id); if(!b) return; b.ontouchstart = (e) => { e.preventDefault(); if(!this.input.includes(key)) this.input.push(key); }; b.ontouchend = (e) => { e.preventDefault(); const i = this.input.indexOf(key); if(i > -1) this.input.splice(i, 1); }; };
