                this.items.forEach(it => it.update()); this.items = this.items.filter(it => !it.markedForDeletion);
                this.blasts.forEach(b => b.update()); this.blasts = this.blasts.filter(b => !b.markedForDeletion);
                this.souls.forEach(s => { s.update(); if(s.markedForDeletion && this.ui.logo) { this.ui.logo.classList.remove('glow-active'); void this.ui.logo.offsetWidth; this.ui.logo.classList.add('glow-active'); } });
                this.souls = this.souls.filter(s => !s.markedForDeletion);
                this.particles.forEach(p => p.update()); this.particles = this.particles.filter(p => p.alpha > 0);
                if (this.pendingInvaders.length > 0) { this.invaders.push(...this.pendingInvaders); this.pendingInvaders = []; }
                if (this.invaders.length === 0 && !this.waveTransitioning) {
                    const c = STAGE_CONFIG[this.currentStage];
                    const isMidBossClear = c.isMidBoss || (c.enemy.includes('inugami'));

                    // 指示：ステージクリア（ボス戦後）のみ弾やエフェクトが消えるのを待つ
                    if (isMidBossClear) {
                        if (this.player.bullets.length > 0 || this.souls.length > 0 || this.blasts.length > 0) return;
                    }

                    this.waveTransitioning = true;
                    if (isMidBossClear) {
                        // ステージクリア演出シーケンス
                        this.gameOver = true; 
                        if (this.bgm) this.bgm.pause(); 
                        this.safePlay(this.clearSound); // 1. ステージクリアSE再生
                        this.player.setWinPose(true);
                        const bonus = Math.ceil(this.stageTime) * 100; 
                        this.score += bonus; 
                        this.ui.score.innerText = this.score;
                        this.ui.stageClear.innerText = `ステージクリア\nボーナス +${bonus}`; 
                        this.ui.stageClear.classList.remove('hidden');

                        // 指定フローの実行
                        setTimeout(() => {
                            this.safePlay(this.recoverySound); // 2. recovery3.oggを鳴らす
                            this.lives = this.maxVisibleHearts; // 3. ライフを満タンまで回復
                            this.updateLivesUI();
                            
                            setTimeout(() => {
                                this.ui.stageClear.classList.add('hidden');
                                
                                // 指示：8面クリア時はエンディングへ、それ以外は次へ
                                if (this.currentMajorStage === 8) {
                                    this.showEnding();
                                } else {
                                    this.currentStage++; 
                                    this.loadStage(this.currentStage); 
                                }
                            }, 1500);
                        }, 1500); 

                    } else { 
                        // 通常ウェーブ移行（1-1から1-2など）は弾の残存を無視して即座に進む
                        setTimeout(() => { this.currentStage++; this.loadStage(this.currentStage); }, 500); 
                    }
                }
            }
            showEnding() {
                this.gameOver = true;
                this.ui.uiLayer.classList.add('hidden');
                this.ui.logo.classList.add('hidden');
                this.ui.endFinalScore.innerText = this.score;
                this.ui.endingScreen.classList.remove('hidden');
                let hs = 0; try { hs = parseInt(localStorage.getItem('wazaika_high_score')) || 0; } catch(e) {}
                if (this.score > hs) localStorage.setItem('wazaika_high_score', this.score);
            }
            checkCollisions() {
                const pHit = { x: this.player.x + 12, y: this.player.y + 10, width: this.player.width - 24, height: this.player.height - 20 };
                const explosions = [];
                this.player.bullets.forEach(b => { 
                    if (b.markedForDeletion) return; 

                    // 隠しアイテムとの衝突判定 (発見前のみ判定)
                    if (!this.hiddenItemFound) {
                        const dist = Math.sqrt(Math.pow(b.x - this.hiddenItemPos.x, 2) + Math.pow(b.y - this.hiddenItemPos.y, 2));
                        if (dist < 20) {
                            this.hiddenItemHits++;
                            this.hiddenItemFlash = 3; 
                            this.safePlay(this.katanaSound); // ヒット音再生
                            b.markedForDeletion = true;
                            if (this.hiddenItemHits >= 3) {
                                this.hiddenItemFound = true;
                                this.unlockSecret(this.currentMajorStage);
                                this.score += 10000;
                                this.ui.score.innerText = this.score;
                                this.safePlay(this.successSound); 
                                for(let i=0; i<50; i++) this.souls.push(new SoulParticle(this.hiddenItemPos.x, this.hiddenItemPos.y, 2));
                                this.blasts.push(new BlastEffect(this.hiddenItemPos.x, this.hiddenItemPos.y, 80));
                            }
                        }
                    }

                    for (let inv of this.invaders) { 
                        if (inv.isVisible && !inv.markedForDeletion && this.rectHit(b, inv)) { 
                            if (b.isLaser) {
                                if (!b.hitEnemies.has(inv)) {
                                    this.applyDamage(inv, b.damage);
                                    b.hitEnemies.add(inv);
                                }
                            } else {
                                b.markedForDeletion = true; 
                                if (b.isExplosive) explosions.push({ x: b.x, y: b.y }); else this.applyDamage(inv, b.damage); 
                                break; 
                            }
                        } 
                    } 
                });
                explosions.forEach(e => { const br = 60; this.blasts.push(new BlastEffect(e.x, e.y, br)); for (let inv of this.invaders) { if (!inv.isVisible || inv.markedForDeletion) continue; const dx = (inv.x + inv.width/2) - e.x, dy = (inv.y + inv.height/2) - e.y; if (Math.sqrt(dx*dx + dy*dy) < br + inv.width/2) this.applyDamage(inv, 3); } });
                
                // アイテム取得判定
                this.items.forEach(it => {
                    if (!it.markedForDeletion && this.rectHit(it, pHit)) {
                        it.markedForDeletion = true;
                        this.safePlay(this.pupSound); // 指示：パワーアップ取得音再生
                        switch(it.type) {
                            case 'totu': this.player.setWeaponByIndex(4); break;
                            case 'baku': this.player.setWeaponByIndex(3); break;
                            case 'ren':  this.player.setWeaponByIndex(1); break;
                            case 'san':  this.player.setWeaponByIndex(2); break;
                        }
                    }
                });

                this.invaderBullets.forEach(b => { 
                    if (!b.markedForDeletion && !this.player.isInvincible && this.rectHit(b, pHit)) { 
                        b.markedForDeletion = true; 
                        if (!DEBUG_INVINCIBLE) { 
                            this.lives--; 
                            this.updateLivesUI(); 
                            this.safePlay(this.playerDamageSound); 
                            this.player.setWeaponByIndex(0);
                            if(this.lives <= 0) this.setGameOver(); 
                            else { this.player.isInvincible = true; this.player.invincibleTimer = 1000; } 
                        } 
                    } 
                });
                this.invaders = this.invaders.filter(i => !i.markedForDeletion);
            }
            applyDamage(inv, dmg) {
                if (inv.markedForDeletion) return; inv.health -= dmg; inv.hitFlash = 3; this.safePlay(this.damageSound);
                if (inv.health <= 0) {
                    inv.markedForDeletion = true; this.score += (inv.isMidBoss ? 100 : 10); this.ui.score.innerText = this.score;
                    this.killedCountInWave++;
                    
                    const stageCfg = STAGE_CONFIG[this.currentStage];
                    if (!stageCfg.isMidBoss && !ENEMY_TYPES[inv.typeName].isBoss && this.killedCountInWave === 3) {
                        const types = ['totu', 'baku', 'ren', 'san'];
                        const dropType = types[Math.floor(Math.random() * types.length)];
                        this.items.push(new Item(inv.x + inv.width/2, inv.y + inv.height/2, dropType));
                    }

                    let sc = 3, sm = 1; if (inv.type.isBoss) { sc = 100; sm = 3; } else if (inv.isMidBoss) { sc = 30; sm = 2; }
                    for(let i=0; i<sc; i++) this.souls.push(new SoulParticle(inv.x + inv.width/2, inv.y + inv.height/2, sm));
                    if (inv.typeName === 'hitotume') { this.invaderBullets.push(new Bullet(inv.x + inv.width / 2, inv.y + inv.height, 3, COLORS.YELLOW, 2, true, 'star', null, 5)); this.invaderBullets.push(new Bullet(inv.x + inv.width / 2, inv.y + inv.height, 3, COLORS.YELLOW, -2, true, 'star', null, 5)); }
                    if (inv.type.splitInto && !inv.isMidBoss) { for(let i=0; i<2; i++) this.pendingInvaders.push(new Invader(inv.x + (i===0?-15:15), inv.y, inv.type.splitInto, this)); }
                    for(let i=0; i<8; i++) this.particles.push(new Particle(inv.x + inv.width/2, inv.y + inv.height/2, inv.color));
                }
            }
            rectHit(r1, r2) { const w1 = r1.width || 16, h1 = r1.height || 16; const rx = r1.x - (r1.radius || 0), ry = r1.y - (r1.radius || 0); return rx < r2.x + r2.width && rx + w1 > r2.x && ry < r2.y + r2.height && ry + h1 > r2.y; }
            setGameOver() { this.gameOver = true; if(this.bgm) { try { this.bgm.pause(); } catch(e) {} this.bgm = null; } this.safePlay(this.gameOverSound); document.getElementById('final-score').innerText = this.score; document.getElementById('game-over-screen').classList.remove('hidden'); let currentHS = parseInt(this.ui.highScore.innerText) || 0; if (this.score > currentHS) localStorage.setItem('wazaika_high_score', this.score); }
            draw() { 
                this.ctx.clearRect(0, 0, 400, 600); 
                if (this.showingOpening && this.openingImage && this.openingImage.complete) { 
                    this.ctx.drawImage(this.openingImage, 0, 0, 400, 600); 
                } else { 
                    if (this.bgImage.complete) this.ctx.drawImage(this.bgImage, 0, 0, 400, 600); 
                    
                    // 隠しアイテムの描画
                    if (this.hiddenItemFound) {
                        this.ctx.save();
                        if (this.hiddenItemImage.complete) {
                            this.ctx.drawImage(this.hiddenItemImage, this.hiddenItemPos.x - 35, this.hiddenItemPos.y - 35, 70, 70);
                        } else {
                            this.ctx.fillStyle = COLORS.GOLD;
                            this.ctx.beginPath();
                            this.ctx.arc(this.hiddenItemPos.x, this.hiddenItemPos.y, 35, 0, Math.PI * 2);
                            this.ctx.fill();
                        }
                        this.ctx.restore();
                    } else if (this.hiddenItemFlash > 0) {
                        // 隠れているときに弾が当たった瞬間のフィードバック（白光り）
                        this.ctx.save();
                        this.ctx.fillStyle = 'rgba(255, 255, 255, 0.8)';
                        this.ctx.beginPath();
                        this.ctx.arc(this.hiddenItemPos.x, this.hiddenItemPos.y, 20, 0, Math.PI * 2);
                        this.ctx.fill();
                        this.hiddenItemFlash--;
                        this.ctx.restore();
                    }

                    this.items.forEach(it => it.draw(this.ctx)); 
                    this.invaders.forEach(i => i.draw(this.ctx)); 
                    this.player.draw(this.ctx); 
                    this.invaderBullets.forEach(b => b.draw(this.ctx)); 
                    this.souls.forEach(s => s.draw(this.ctx)); 
                    this.blasts.forEach(b => b.draw(this.ctx)); 
                    this.particles.forEach(p => p.draw(this.ctx)); 
                } 
            }
            loop() { this.update(); this.draw(); requestAnimationFrame(this.loop.bind(this)); }
        }
        window.onload = () => new Game();
    </script>
