            }
            createInvaders(config) {
                this.invaders = [];
                const { enemy, rows, cols, isMidBoss } = config;
                const type = ENEMY_TYPES[enemy];
                
                if (isMidBoss || type.isBoss) {
                    if (isMidBoss && cols > 0) {
                        const spacing = 80;
                        const totalW = (cols - 1) * spacing;
                        const startX = CANVAS_LOGICAL_WIDTH / 2 - totalW / 2 - (type.maxWidth * 2) / 2;
                        for(let c=0; c<cols; c++) {
