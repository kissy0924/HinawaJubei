                        this.invaderBullets.push(new Bullet(s.x + s.width/2, s.y + s.height, vy, cfg.bulletColor || COLORS.YELLOW, vx, true, cfg.bulletShape || 'circle', cfg.bulletImage, cfg.bulletRadius || 5));
                    }
