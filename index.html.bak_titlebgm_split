<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>わざいか！種子島妖怪大決戦</title>
    <style>
        /**
         * Wazaika! Tanegashima Youkai Daikessen - FULL SPEC RESTORED & ULTIMATE STABLE
         */
        :root {
            --neon-cyan: #0ff;
            --neon-magenta: #f0f;
            --neon-yellow: #ff0;
            --bg-dark: #0a0a0f;
            --text-color: #fff;
            --gold-glow: #ffd700;
        }

        @font-face {
            font-family: 'DotGothic16';
            src: url('DotGothic16-Regular.ttf') format('truetype');
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            margin: 0;
            padding: 0;
            background: #000;
            font-family: 'DotGothic16', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow: hidden;
            user-select: none;
            touch-action: none;
        }

        #game-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        #game-container {
            position: relative;
            width: 400px;
            height: 600px;
            background: #111;
            border: 2px solid var(--neon-cyan);
            box-shadow: 0 0 15px var(--neon-cyan);
            overflow: hidden;
        }

        #tanepay-logo {
            position: absolute;
            top: 5px;
            left: 50%;
            transform: translateX(-50%);
            width: 100px;
            height: auto;
            z-index: 5;
            pointer-events: none;
        }

        #tanepay-logo.glow-active {
            animation: logo-glow-anim 0.3s ease-out forwards;
        }

        @keyframes logo-glow-anim {
            0% { filter: drop-shadow(0 0 0px var(--gold-glow)) brightness(1); }
            50% { filter: drop-shadow(0 0 15px var(--gold-glow)) brightness(1.5); }
            100% { filter: drop-shadow(0 0 4px var(--gold-glow)) brightness(1.1); }
        }

        #gameCanvas {
            display: block;
            width: 400px;
            height: 600px;
            image-rendering: pixelated;
        }

        #ui-layer {
            position: absolute;
            inset: 0;
            pointer-events: none;
            z-index: 10;
        }

        #score-board {
            position: absolute;
            top: 10px;
            left: 255px; 
            font-size: 30px; 
            color: var(--neon-yellow);
            text-shadow: 2px 2px 4px #000, 0 0 10px var(--gold-glow);
        }

        #lives-display {
            position: absolute;
            top: 50px; 
            left: 255px;
            display: flex;
            gap: 2px; 
        }

        .heart-icon {
            width: 24px;
            height: 24px;
            image-rendering: pixelated;
        }

        #stage-display, #time-display, #weapon-display {
            position: absolute;
            font-size: 26px; 
            color: var(--text-color);
            text-shadow: 2px 2px 4px #000, 0 0 5px var(--neon-cyan);
        }

        /* ステージとタイムを横一列に配置 */
        #stage-display { top: 10px; left: 10px; }
        #time-display  { top: 10px; left: 110px; } 

        #weapon-display { 
            top: 45px; 
            left: 0px; 
            color: var(--neon-cyan); 
            pointer-events: auto; 
            cursor: pointer;
            display: flex;
            align-items: center;
        }

        #weapon-img {
            height: 54px; 
            width: auto;
            image-rendering: pixelated;
        }

        #high-score-board {
            position: absolute;
            top: 40px;
            width: 100%;
            text-align: center;
            font-size: 32px;
            color: var(--neon-yellow);
            text-shadow: 0 0 15px var(--neon-yellow), 3px 3px 6px #000;
            z-index: 45;
            pointer-events: none;
        }

        #stage-clear {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 24px;
            color: var(--neon-yellow);
            text-shadow: 0 0 10px var(--neon-yellow), 2px 2px #000;
            z-index: 20;
            text-align: center;
            white-space: pre-wrap;
            pointer-events: none;
        }

        .overlay {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.85);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 40;
            padding: 20px;
        }

        #start-screen {
            background-image: url("tittle.png");
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center;
            cursor: pointer;
        }

        .title-btns {
            margin-top: 220px;
            display: flex;
            gap: 16px;
            pointer-events: auto;
        }

        .title-btn {
            padding: 10px 16px;
            min-width: 140px;
            font-family: 'DotGothic16', sans-serif;
            font-size: 26px;
            letter-spacing: 2px;
            color: var(--neon-cyan);
            background: rgba(0, 255, 255, 0.08);
            border: 2px solid var(--neon-cyan);
            border-radius: 10px;
            cursor: pointer;
        }

        #secret-screen {
            background: #000;
            cursor: pointer;
            padding: 0;
        }

        .secret-col {
            position: absolute;
            top: 0;
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        .secret-col.left { left: 0; }
        .secret-col.right { right: 0; }

        .secret-col img {
            display: block;
        }

        .secret-col img[data-secret-id] {
            visibility: hidden;
        }

        #game-over-screen {
            background: rgba(10, 0, 0, 0.8);
            cursor: pointer;
        }

        #game-over-screen h1 {
            color: var(--neon-magenta);
            text-shadow: 0 0 20px var(--neon-magenta), 3px 3px #000;
            font-size: 48px;
            margin-bottom: 10px;
        }

        #game-over-image {
            width: 140px;
            height: auto;
            margin-bottom: 20px;
            filter: drop-shadow(0 0 15px var(--neon-magenta));
        }

        #ending-screen {
            background: #000;
            cursor: pointer;
        }

        #ending-image {
            width: 100%;
            height: auto;
            max-height: 400px;
            object-fit: contain;
            margin-bottom: 20px;
        }

        #mobile-controls {
            display: flex;
            width: 400px;
            height: 100px;
            background: #111;
            border: 2px solid var(--neon-cyan);
            border-top: none;
            padding: 10px;
            gap: 10px;
        }

        .control-btn {
            flex: 1; 
            background: rgba(0, 255, 255, 0.1);
            border: 2px solid var(--neon-cyan);
            border-radius: 10px;
            color: var(--neon-cyan);
            font-family: 'DotGothic16', sans-serif;
            font-size: 32px; 
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;
        }

        .hidden { display: none !important; }
        .blink { animation: blink 0.8s infinite; }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
    </style>
</head>
<body>
    <div id="game-wrapper">
        <div id="game-container">
            <img id="tanepay-logo" class="hidden" src="tanepay.png" alt="Tanepay">
            <div id="high-score-board">最高記録: <span id="high-score">0</span></div>
            <canvas id="gameCanvas"></canvas>
            <div id="ui-layer" class="hidden">
                <div id="score-board"><span id="score">0</span></div>
                <div id="lives-display">
                    <img id="heart-0" class="heart-icon" src="herat_01.png">
                    <img id="heart-1" class="heart-icon" src="herat_01.png">
                    <img id="heart-2" class="heart-icon" src="herat_01.png">
                    <img id="heart-3" class="heart-icon" src="heart_00.png" style="display:none">
                    <img id="heart-4" class="heart-icon" src="heart_00.png" style="display:none">
                </div>
                <!-- ラベルテキスト削除済、横並び配置 -->
                <div id="stage-display"><span id="stage">1-1</span></div>
                <div id="time-display"><span id="time">100</span></div>
                <div id="weapon-display">
                    <img id="weapon-img" src="zyu_normal.png" alt="武器">
                </div>
            </div>
            <div id="stage-clear" class="hidden"></div>
            <div id="start-screen" class="overlay">
                <div class="title-btns">
                    <button id="btn-start" class="title-btn">スタート</button>
                    <button id="btn-secret" class="title-btn">シークレット</button>
                </div>
            </div>
            <div id="game-over-screen" class="overlay hidden">
                <h1>ゲームオーバー</h1>
                <img id="game-over-image" src="player_gameover.png" alt="敗北">
                <p style="color:var(--neon-yellow);font-size:24px;">最終スコア: <span id="final-score">0</span></p>
                <p class="blink" style="color:var(--neon-cyan);font-size:32px;margin-top:20px;">再挑戦する！</p>
            </div>
            <div id="ending-screen" class="overlay hidden">
                <img id="ending-image" src="ending.png" alt="エンディング">
                <p style="color:var(--neon-yellow);font-size:28px;margin-bottom:10px;">祝！種子島妖怪大決戦 制覇</p>
                <p style="color:var(--text-color);font-size:24px;">最終スコア: <span id="end-final-score">0</span></p>
                <p class="blink" style="color:var(--neon-cyan);font-size:32px;margin-top:30px;">タップでタイトルへ</p>
            </div>
            <div id="secret-screen" class="overlay hidden">
                <div class="secret-col left">
                    <img src="secret_left01.png" alt="secret_left01" data-secret-id="1">
                    <img src="secret_left02.png" alt="secret_left02" data-secret-id="2">
                    <img src="secret_left03.png" alt="secret_left03" data-secret-id="3">
                    <img src="secret_left04.png" alt="secret_left04" data-secret-id="4">
                </div>
                <div class="secret-col right">
                    <img src="secret_right00.png" alt="secret_right00">
                    <img src="secret_right01.png" alt="secret_right01" data-secret-id="5">
                    <img src="secret_right02.png" alt="secret_right02" data-secret-id="6">
                    <img src="secret_right03.png" alt="secret_right03" data-secret-id="7">
                    <img src="secret_right04.png" alt="secret_right04" data-secret-id="8">
                </div>
            </div>
        </div>
        <div id="mobile-controls">
            <button id="btn-left" class="control-btn">←</button>
            <button id="btn-right" class="control-btn">→</button>
        </div>
    </div>
    <script>
        const CANVAS_LOGICAL_WIDTH = 400;
        const CANVAS_LOGICAL_HEIGHT = 600;
        const DEBUG_INVINCIBLE = false; // 無敵モードを解除

        const COLORS = {
            CYAN: '#0ff', MAGENTA: '#f0f', YELLOW: '#ff0', WHITE: '#fff', RED: '#f00', GREEN: '#0f0', GOLD: '#ffd700'
        };

        const ENEMY_TYPES = {
            kapa: { image: 'kapa.png', maxWidth: 50, health: 1, color: COLORS.MAGENTA, bulletShape: 'circle', bulletColor: COLORS.CYAN },
            kapa02: { image: 'kapa02.png', maxWidth: 50, health: 2, color: COLORS.MAGENTA, bulletShape: 'circle', bulletColor: COLORS.CYAN },
            kapa03: { image: 'kapa03.png', maxWidth: 50, health: 1, midBossHealth: 10, color: COLORS.MAGENTA, bulletShape: 'circle', bulletColor: COLORS.CYAN },
            hyoutan: { image: 'hyoutan.png', maxWidth: 50, health: 1, color: COLORS.YELLOW, splitInto: 'miniHyoutan', bulletShape: 'wave', bulletColor: COLORS.GREEN, bulletRadius: 10 },
            hyoutan_nosplit: { image: 'hyoutan.png', maxWidth: 50, health: 1, color: COLORS.YELLOW, bulletShape: 'wave', bulletColor: COLORS.GREEN, bulletRadius: 10 },
            hyoutan02: { image: 'hyoutan02.png', maxWidth: 50, health: 1, color: COLORS.YELLOW, splitInto: 'miniHyoutan', bulletShape: 'wave', bulletColor: COLORS.GREEN, bulletRadius: 10 },
            hyoutan03: { image: 'hyoutan03.png', maxWidth: 50, health: 1, midBossHealth: 8, color: COLORS.YELLOW, splitInto: 'miniHyoutan', bulletShape: 'wave', bulletColor: COLORS.GREEN, bulletRadius: 10 },
            miniHyoutan: { image: 'hyoutan.png', maxWidth: 25, health: 1, color: COLORS.YELLOW, bulletShape: 'wave', bulletColor: COLORS.GREEN, bulletRadius: 10 },
            hitotume: { image: 'hitotume.png', maxWidth: 50, health: 2, color: COLORS.CYAN, bulletShape: 'star', bulletColor: COLORS.YELLOW },
            hitotume02: { image: 'hitotume02.png', maxWidth: 50, health: 4, color: COLORS.CYAN, bulletShape: 'star', bulletColor: COLORS.YELLOW },
            hitotume03: { image: 'hitotume03.png', maxWidth: 50, health: 2, midBossHealth: 12, color: COLORS.CYAN, bulletShape: 'star', bulletColor: COLORS.YELLOW },
            nuriyome: { image: 'nuriyome.png', maxWidth: 50, health: 1, color: COLORS.WHITE, canHide: true, bulletShape: 'magatama', bulletColor: COLORS.CYAN },
            nuriyome02: { image: 'nuriyome02.png', maxWidth: 50, health: 1, color: COLORS.WHITE, canHide: true, bulletShape: 'magatama', bulletColor: COLORS.CYAN },
            nuriyome03: { image: 'nuriyome03.png', maxWidth: 50, health: 1, midBossHealth: 8, color: COLORS.WHITE, canHide: true, bulletShape: 'magatama', bulletColor: COLORS.CYAN },
            oni: { image: 'oni.png', maxWidth: 80, health: 3, color: COLORS.RED, verticalMove: true, bulletShape: 'diamond', bulletColor: COLORS.RED },
            oni02: { image: 'oni02.png', maxWidth: 80, health: 3, color: COLORS.RED, verticalMove: true, bulletShape: 'diamond', bulletColor: COLORS.RED },
            oni03: { image: 'oni03.png', maxWidth: 80, health: 3, midBossHealth: 20, color: COLORS.RED, verticalMove: true, bulletShape: 'diamond', bulletColor: COLORS.RED },
            tengu: { image: 'tengu.png', maxWidth: 62, health: 5, midBossHealth: 5, color: COLORS.YELLOW, randomMove: true, bulletImage: 'hane.png' },
            inugami01: { image: 'inugami01.png', maxWidth: 240, health: 40, color: COLORS.RED, isBoss: true, circleMove: true },
            inugami02: { image: 'inugami02.png', maxWidth: 90, health: 60, color: COLORS.MAGENTA, isBoss: true, randomMove: true }
        };

        const STAGE_CONFIG = [
            { enemy: 'kapa', rows: 3, cols: 5, speed: 0.5, enemyBulletVy: 1, bg: 'st_01.png', bgm: 'STAGE-01.mp3', opening: 'OP01.png', waveLabel: '1-1' },
            { enemy: 'kapa02', rows: 3, cols: 5, speed: 0.75, enemyBulletVy: 2, bg: 'st_01.png', bgm: 'STAGE-01.mp3', waveLabel: '1-2' },
            { enemy: 'kapa03', isMidBoss: true, speed: 1.0, bg: 'st_01.png', bgm: 'STAGE-01.mp3', waveLabel: '1-3' },
            { enemy: 'hyoutan_nosplit', rows: 3, cols: 4, speed: 0.5, bg: 'st_02.png', bgm: 'STAGE-02.mp3', opening: 'OP02.png', waveLabel: '2-1' },
            { enemy: 'hyoutan02', rows: 3, cols: 4, speed: 0.75, bg: 'st_02.png', bgm: 'STAGE-02.mp3', waveLabel: '2-2' },
            { enemy: 'hyoutan03', isMidBoss: true, speed: 1.0, bg: 'st_02.png', bgm: 'STAGE-02.mp3', waveLabel: '2-3' },
            { enemy: 'hitotume', rows: 4, cols: 4, speed: 0.75, bg: 'st_03.png', bgm: 'STAGE-03.mp3', opening: 'OP03.png', waveLabel: '3-1' },
            { enemy: 'hitotume02', rows: 4, cols: 4, speed: 1.0, bg: 'st_03.png', bgm: 'STAGE-03.mp3', waveLabel: '3-2' },
            { enemy: 'hitotume03', isMidBoss: true, speed: 1.5, bg: 'st_03.png', bgm: 'STAGE-03.mp3', waveLabel: '3-3' },
            { enemy: 'nuriyome', rows: 5, cols: 3, speed: 0.0, bg: 'st_04.png', bgm: 'STAGE-04.mp3', opening: 'OP04.png', waveLabel: '4-1' },
            { enemy: 'nuriyome02', rows: 5, cols: 3, speed: 0.0, bg: 'st_04.png', bgm: 'STAGE-04.mp3', waveLabel: '4-2' },
            { enemy: 'nuriyome03', isMidBoss: true, speed: 0.0, bg: 'st_04.png', bgm: 'STAGE-04.mp3', waveLabel: '4-3' },
            { enemy: 'oni', rows: 5, cols: 3, speed: 1.2, bg: 'st_05.png', bgm: 'STAGE-05.mp3', opening: 'OP05.png', waveLabel: '5-1' },
            { enemy: 'oni02', rows: 5, cols: 3, speed: 1.2, bg: 'st_05.png', bgm: 'STAGE-05.mp3', waveLabel: '5-2' },
            { enemy: 'oni03', isMidBoss: true, speed: 1.8, bg: 'st_05.png', bgm: 'STAGE-05.mp3', waveLabel: '5-3' },
            { enemy: 'tengu', rows: 1, cols: 3, speed: 1.8, bg: 'st_06.png', bgm: 'STAGE-06.mp3', opening: 'OP06.png', waveLabel: '6', isMidBoss: true },
            { enemy: 'inugami01', rows: 1, cols: 1, speed: 0.0, bg: 'st_07.png', bgm: 'STAGE-07.mp3', opening: 'OP07.png', waveLabel: '7' },
            { enemy: 'inugami02', rows: 1, cols: 1, speed: 2.5, bg: 'st_08.png', bgm: 'STAGE-08.mp3', opening: 'OP08.png', waveLabel: '8' }
        ];

        // ウェーブ番号をメジャーステージ番号(1-8)に紐付け
        const STAGE_MAP = [1, 1, 1, 2, 2, 2, 3, 3, 3, 4, 4, 4, 5, 5, 5, 6, 7, 8];

        // ステージごとの隠しアイテム座標 (全8ステージ)
        const HIDDEN_ITEM_POSITIONS = [
            {x: 50, y: 150},  // Stage 1
            {x: 350, y: 200}, // Stage 2
            {x: 250, y: 400}, // Stage 3
            {x: 100, y: 350}, // Stage 4
            {x: 300, y: 300}, // Stage 5
            {x: 150, y: 500}, // Stage 6
            {x: 200, y: 250}, // Stage 7
            {x: 350, y: 450}  // Stage 8
        ];

        class SoulParticle {
            constructor(x, y, sizeMult = 1) {
                this.x = x + (Math.random() - 0.5) * 40;
                this.y = y + (Math.random() - 0.5) * 40;
                this.targetX = 200; this.targetY = 25;
                this.speed = 1.0 + Math.random() * 2; this.accel = 1.12; 
                this.markedForDeletion = false;
                this.size = (0.8 + Math.random() * 1.2) * sizeMult;
            }
            update() {
                const dx = this.targetX - this.x, dy = this.targetY - this.y, dist = Math.sqrt(dx * dx + dy * dy);
                if (dist < 10 || this.speed > dist) { this.markedForDeletion = true; return; }
                this.x += (dx / dist) * this.speed; this.y += (dy / dist) * this.speed;
                this.speed *= this.accel;
            }
            draw(ctx) {
                ctx.save(); ctx.fillStyle = COLORS.GOLD; ctx.globalAlpha = 0.3;
                ctx.beginPath(); ctx.arc(this.x, this.y, this.size * 3.5, 0, Math.PI * 2); ctx.fill();
                ctx.globalAlpha = 0.7; ctx.beginPath(); ctx.arc(this.x, this.y, this.size * 2, 0, Math.PI * 2); ctx.fill();
                ctx.fillStyle = COLORS.WHITE; ctx.globalAlpha = 1.0; ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2); ctx.fill();
                ctx.restore();
            }
        }

        class BlastEffect {
            constructor(x, y, radius) {
                this.x = x; this.y = y; this.maxRadius = radius;
                this.currentRadius = 0; this.alpha = 1;
                this.markedForDeletion = false;
            }
            update() { this.currentRadius += 7; this.alpha -= 0.05; if (this.alpha <= 0) this.markedForDeletion = true; }
            draw(ctx) { ctx.save(); ctx.globalAlpha = Math.max(0, this.alpha); ctx.fillStyle = COLORS.GOLD; ctx.beginPath(); ctx.arc(this.x, this.y, this.currentRadius, 0, Math.PI * 2); ctx.fill(); ctx.restore(); }
        }

        class Bullet {
            constructor(x, y, vy, color, vx = 0, isEnemy = false, shape = 'circle', imgSource = null, radius = 5, isExplosive = false, isLaser = false, damage = 1) {
                this.x = x; this.y = y; this.vy = vy; this.vx = vx;
                this.radius = radius; this.width = radius * 2; this.height = radius * 2;
                this.color = color; this.markedForDeletion = false; this.isExplosive = isExplosive; 
                this.isEnemy = isEnemy; this.shape = shape; this.isLaser = isLaser; this.damage = damage;
                this.bulletImg = null; if (imgSource) { this.bulletImg = new Image(); this.bulletImg.src = imgSource; }
                this.hitEnemies = new Set();
            }
            update() { 
                this.y += this.vy; this.x += this.vx;
                if (this.y < -150 || this.y > 750 || this.x < -150 || this.x > 550) this.markedForDeletion = true; 
            }
            draw(ctx) {
                ctx.save();
                if (this.bulletImg && this.bulletImg.complete) { ctx.drawImage(this.bulletImg, this.x - this.radius, this.y - this.radius, this.radius*2, this.radius*2); ctx.restore(); return; }
                ctx.fillStyle = this.color; ctx.strokeStyle = this.color; ctx.lineWidth = 2;
                if (this.isLaser) {
                    ctx.shadowBlur = 10; ctx.shadowColor = COLORS.CYAN;
                    ctx.fillRect(this.x - 2, this.y, 4, 30);
                } else if (this.isExplosive) { ctx.beginPath(); ctx.arc(this.x, this.y, 8, 0, Math.PI * 2); ctx.fill(); }
                else if (this.shape === 'diamond') {
                    ctx.beginPath(); ctx.moveTo(this.x, this.y - this.radius); ctx.lineTo(this.x + this.radius, this.y); ctx.lineTo(this.x, this.y + this.radius); ctx.lineTo(this.x - this.radius, this.y); ctx.closePath(); ctx.fill();
                } else if (this.shape === 'star') {
                    ctx.beginPath(); for(let i=0; i<5; i++) { ctx.lineTo(this.x + Math.cos((18+i*72)/180*Math.PI)*this.radius, this.y + Math.sin((18+i*72)/180*Math.PI)*this.radius); ctx.lineTo(this.x + Math.cos((54+i*72)/180*Math.PI)*(this.radius/2), this.y + Math.sin((54+i*72)/180*Math.PI)*(this.radius/2)); }
                    ctx.closePath(); ctx.fill();
                } else if (this.shape === 'wave') {
                    ctx.beginPath(); ctx.moveTo(this.x, this.y - this.radius);
                    ctx.bezierCurveTo(this.x + this.radius*2, this.y, this.x - this.radius*2, this.y, this.x, this.y + this.radius); ctx.stroke();
                } else if (this.shape === 'magatama') {
                    ctx.beginPath(); ctx.arc(this.x, this.y - 2, this.radius - 2, 0, Math.PI * 2); ctx.fill();
                    ctx.beginPath(); ctx.arc(this.x, this.y, this.radius, -Math.PI / 2, Math.PI / 2);
                    ctx.quadraticCurveTo(this.x - this.radius, this.y + this.radius, this.x - this.radius, this.y); ctx.fill();
